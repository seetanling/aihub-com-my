# ──────────────────────────────────────────────
# aihub.com.my — environment variables
# Copy to .env.local for local dev
# Never commit .env.local
# ──────────────────────────────────────────────

# Site
NEXT_PUBLIC_SITE_URL=https://aihub.com.my

# Discord / Telegram community invite links
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/your-invite
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/your-channel

# Lead capture — Resend (email) or Lark webhook
# Pick one and fill it in
RESEND_API_KEY=
LARK_WEBHOOK_URL=

# Optional: real-time attendees (future)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
